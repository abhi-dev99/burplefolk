# Copy this file to .streamlit/secrets.toml and fill in your values.
# Environment variables take PRECEDENCE over values here.
# To use environment variables instead: export FIREBASE_API_KEY=xxx OLLAMA_ENDPOINT=xxx, etc.
#
# These values are read by Streamlit prototype auth in app.py.
# For local development, you can leave them empty (use environment variables instead).

# Ollama (Local LLM)
OLLAMA_ENDPOINT = "http://localhost:11434"
OLLAMA_API_KEY = ""

# Firebase (Agent Login)
FIREBASE_API_KEY = ""
FIREBASE_AUTH_DOMAIN = ""
FIREBASE_PROJECT_ID = ""
FIREBASE_STORAGE_BUCKET = ""
AGENT_DEFAULT_EMAIL = "burplefolk@gmail.com"
